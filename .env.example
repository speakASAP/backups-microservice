# ============================================
# Identity
# ============================================
NODE_ENV=
SERVICE_NAME=backups-microservice
DOMAIN=

# ============================================
# Ports
# ============================================
PORT=3398

# ============================================
# Shared Microservices
# ============================================
AUTH_SERVICE_URL=
LOGGING_SERVICE_URL=
LOGGING_SERVICE_API_PATH=/api/logs
NOTIFICATION_SERVICE_URL=
MONITORING_SERVICE_URL=

# ============================================
# Database (Shared PostgreSQL)
# ============================================
DB_HOST=
DB_PORT=5432
DB_USER=dbadmin
DB_PASSWORD=
DB_NAME=backups

# ============================================
# MinIO Storage
# ============================================
MINIO_SERVICE_URL=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BACKUP_BUCKET=backups

# ============================================
# Backup Config
# ============================================
BACKUP_SCHEDULE_DB=0 2 * * *
BACKUP_RETENTION_DAYS=30

# ============================================
# Secrets
# ============================================
JWT_SECRET=
